generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

enum Role {
  PLANNER
  PILOT
  COMMANDER
}

enum MissionType {
  TRAINING
  OPERATIONAL
}

enum MissionStatus {
  DRAFT
  PLANNED
  UNDER_REVIEW
  APPROVED
  REJECTED
  BRIEFED
  EXECUTING
  DEBRIEFED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum WaypointType {
  INITIAL_POINT
  WAYPOINT
  TARGET
  EGRESS_POINT
  LANDING
  RALLY_POINT
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         Role
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  createdMissions  Mission[] @relation("CreatedBy")
  approvedMissions Mission[] @relation("ApprovedBy")

  @@map("users")
}

model Mission {
  id                String        @id @default(uuid())
  name              String
  type              MissionType
  status            MissionStatus @default(DRAFT)
  priority          Priority      @default(MEDIUM)
  scheduledStart    DateTime?     @map("scheduled_start")
  scheduledEnd      DateTime?     @map("scheduled_end")
  commanderComments String?       @map("commander_comments")
  createdById       String        @map("created_by_id")
  approvedById      String?       @map("approved_by_id")
  isTemplate          Boolean       @default(false) @map("is_template")
  templateName        String?       @map("template_name")
  templateDescription String?       @map("template_description")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  createdBy            User                  @relation("CreatedBy", fields: [createdById], references: [id])
  approvedBy           User?                 @relation("ApprovedBy", fields: [approvedById], references: [id])
  aircraft             Aircraft[]
  crewMembers          CrewMember[]
  waypoints            Waypoint[]
  missionThreats       MissionThreat[]
  weatherReports       WeatherReport[]
  deconflictionResults DeconflictionResult[]
  versions             MissionVersion[]

  @@map("missions")
}

model Aircraft {
  id         String @id @default(uuid())
  missionId  String @map("mission_id")
  type       String
  tailNumber String @map("tail_number")
  callsign   String

  mission     Mission      @relation(fields: [missionId], references: [id], onDelete: Cascade)
  crewMembers CrewMember[]

  @@map("aircraft")
}

model CrewMember {
  id         String  @id @default(uuid())
  missionId  String  @map("mission_id")
  aircraftId String? @map("aircraft_id")
  role       String
  name       String

  mission  Mission   @relation(fields: [missionId], references: [id], onDelete: Cascade)
  aircraft Aircraft? @relation(fields: [aircraftId], references: [id], onDelete: SetNull)

  @@map("crew_members")
}

model Waypoint {
  id            String       @id @default(uuid())
  missionId     String       @map("mission_id")
  sequenceOrder Int          @map("sequence_order")
  name          String?
  lat           Float
  lon           Float
  altitude      Float?
  speed         Float?
  timeOnTarget  DateTime?    @map("time_on_target")
  type          WaypointType @default(WAYPOINT)

  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@unique([missionId, sequenceOrder])
  @@map("waypoints")
}

enum ThreatCategory {
  SAM
  AAA
  MANPAD
  RADAR
  FIGHTER
  OTHER
}

enum Lethality {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ConflictType {
  AIRSPACE
  TIMING
  RESOURCE
  RESTRICTED_AIRSPACE
}

enum ConflictSeverity {
  INFO
  WARNING
  CRITICAL
}

enum ConflictResolution {
  UNRESOLVED
  RESOLVED
  ACCEPTED
}

model Threat {
  id          String          @id @default(uuid())
  name        String
  category    ThreatCategory
  lat         Float
  lon         Float
  rangeNm     Float           @map("range_nm")
  lethality   Lethality
  minAltitude Float?          @map("min_altitude")
  maxAltitude Float?          @map("max_altitude")
  active      Boolean         @default(true)
  source      String          @default("manual")
  notes       String?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  missionThreats MissionThreat[]

  @@map("threats")
}

model MissionThreat {
  id        String  @id @default(uuid())
  missionId String  @map("mission_id")
  threatId  String  @map("threat_id")
  notes     String?

  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  threat  Threat  @relation(fields: [threatId], references: [id], onDelete: Cascade)

  @@unique([missionId, threatId])
  @@map("mission_threats")
}

model WeatherReport {
  id          String   @id @default(uuid())
  missionId   String   @map("mission_id")
  stationId   String   @map("station_id")
  type        String
  rawReport   String   @map("raw_report")
  temperature Float?
  windSpeed   Float?   @map("wind_speed")
  windDir     Float?   @map("wind_dir")
  visibility  Float?
  ceiling     Float?
  conditions  String?
  isManual    Boolean  @default(false) @map("is_manual")
  observedAt  DateTime @map("observed_at")
  createdAt   DateTime @default(now()) @map("created_at")

  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@map("weather_reports")
}

model DeconflictionResult {
  id           String             @id @default(uuid())
  missionId    String             @map("mission_id")
  conflictType ConflictType       @map("conflict_type")
  severity     ConflictSeverity
  description  String
  resolution   ConflictResolution @default(UNRESOLVED)
  resolvedBy   String?            @map("resolved_by")
  resolvedAt   DateTime?          @map("resolved_at")
  details      Json?
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@map("deconfliction_results")
}

enum AirspaceType {
  RESTRICTED
  PROHIBITED
  MOA
  WARNING
  ALERT
  TFR
}

model Airspace {
  id          String       @id @default(uuid())
  name        String
  type        AirspaceType
  minAltitude Float?       @map("min_altitude")
  maxAltitude Float?       @map("max_altitude")
  active      Boolean      @default(true)
  coordinates Json         // Array of [lon, lat] pairs forming polygon
  notes       String?
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@map("airspaces")
}

model MissionVersion {
  id        String   @id @default(uuid())
  missionId String   @map("mission_id")
  version   Int
  snapshot  Json
  changedBy String   @map("changed_by")
  changeType String  @map("change_type")
  createdAt DateTime @default(now()) @map("created_at")

  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@unique([missionId, version])
  @@map("mission_versions")
}
